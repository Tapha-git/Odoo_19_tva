<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_l10n_sn_vat_audit_wizard_form" model="ir.ui.view">
        <field name="name">l10n_sn.vat.audit.wizard.form</field>
        <field name="model">l10n_sn.vat.audit.wizard</field>
        <field name="arch" type="xml">
            <form string="Contrôle TVA Sénégal">
                <header>
                    <button name="action_compute"
                            type="object"
                            string="Lancer le contrôle"
                            class="btn-primary"/>
                    <button name="action_export_csv"
                            type="object"
                            string="Exporter le détail CSV"
                            class="btn-secondary"
                            invisible="not line_ids"/>
                    <button name="action_print_dgid_vat_declaration"
                            type="object"
                            string="Imprimer la déclaration TVA (PDF)"
                            class="btn-secondary"/>
                </header>
                <sheet>
                    <group>
                        <group>
                            <field name="company_id" options="{'no_create': True}"/>
                        </group>
                        <group string="Période comptable">
                            <field name="date_from"/>
                            <field name="date_to"/>
                        </group>
                    </group>
                    <group string="Références eTax / DGID">
                        <group>
                            <field name="document_number"/>
                            <field name="submission_number"/>
                        </group>
                        <group>
                            <field name="submitted_date"/>
                            <field name="previous_form_credit"/>
                        </group>
                    </group>
                    <group string="Synthèse">
                        <group>
                            <field name="collected_vat"/>
                            <field name="booked_deductible_vat"/>
                            <field name="eligible_deductible_vat"/>
                        </group>
                        <group>
                            <field name="estimated_balance"
                                   decoration-danger="estimated_balance &gt; 0"
                                   decoration-success="estimated_balance &lt;= 0"/>
                            <field name="anomaly_count"
                                   decoration-danger="anomaly_count &gt; 0"
                                   decoration-success="anomaly_count == 0"/>
                        </group>
                    </group>
                    <field name="currency_id" invisible="1"/>
                    <field name="line_ids" nolabel="1" readonly="1">
                        <list create="0" delete="0" editable="bottom"
                              decoration-warning="control_state == 'to_review'"
                              decoration-muted="control_state == 'excluded'">
                            <field name="move_date"/>
                            <field name="move_id"/>
                            <field name="partner_id"/>
                            <field name="operation_type"/>
                            <field name="tax_name"/>
                            <field name="tax_rate"/>
                            <field name="base_amount" sum="Total base"/>
                            <field name="tax_amount" sum="Total TVA"/>
                            <field name="control_state" widget="badge"
                                   decoration-success="control_state == 'compliant'"
                                   decoration-warning="control_state == 'to_review'"
                                   decoration-danger="control_state == 'excluded'"/>
                            <field name="issue_summary"/>
                        </list>
                    </field>
                </sheet>
                <footer>
                    <button string="Fermer" special="cancel" class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_l10n_sn_vat_audit_wizard" model="ir.actions.act_window">
        <field name="name">Contrôle TVA Sénégal</field>
        <field name="res_model">l10n_sn.vat.audit.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

    <menuitem id="menu_l10n_sn_vat_audit"
              name="Contrôle TVA Sénégal"
              parent="account.account_reports_legal_statements_menu"
              action="action_l10n_sn_vat_audit_wizard"
              sequence="15"
              groups="account.group_account_user"/>
</odoo>
