<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_move_form_sn_vat_compliance" model="ir.ui.view">
        <field name="name">account.move.form.sn.vat.compliance</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_move_form"/>
        <field name="arch" type="xml">
            <field name="company_id" position="after">
                <field name="sn_is_senegal_company" invisible="1"/>
            </field>
            <group id="header_right_group" position="after">
                <group string="TVA Sénégal"
                       invisible="not sn_is_senegal_company or move_type not in ('in_invoice', 'in_refund', 'in_receipt')">
                    <field name="sn_vat_document_type" readonly="state != 'draft'"/>
                    <field name="sn_vat_deduction_status"/>
                    <field name="sn_customs_reference"
                           invisible="sn_vat_document_type != 'import'"/>
                    <field name="sn_vat_supporting_reference"/>
                    <field name="sn_vat_exclusion_reason"
                           invisible="sn_vat_deduction_status != 'excluded'"/>
                    <field name="sn_vat_compliance_state"
                           widget="badge"
                           decoration-success="sn_vat_compliance_state == 'compliant'"
                           decoration-warning="sn_vat_compliance_state == 'to_review'"
                           decoration-danger="sn_vat_compliance_state == 'excluded'"/>
                    <field name="sn_vat_compliance_message"
                           readonly="1"
                           invisible="sn_vat_compliance_state == 'not_applicable'"/>
                </group>
            </group>
        </field>
    </record>
</odoo>
