<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_company_form_sn_tax_information" model="ir.ui.view">
        <field name="name">res.company.form.sn.tax.information</field>
        <field name="model">res.company</field>
        <field name="inherit_id" ref="base.view_company_form"/>
        <field name="arch" type="xml">
            <field name="company_registry" position="after">
                <field name="sn_tax_account"/>
                <field name="sn_tax_division"/>
                <field name="sn_collection_location"/>
                <field name="sn_tax_establishment"/>
                <field name="sn_taxable_object"/>
            </field>
        </field>
    </record>
</odoo>
